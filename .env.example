# Copy to .env.local (gitignored) and fill in to turn on sign-in + write
# protection. With these unset the app runs in local owner mode: no sign-in
# button, full editing, unprotected API writes.

# OAuth 2.0 Client ID (Web application) from Google Cloud Console.
# Authorized JavaScript origins must include http://localhost:5174
# (and your Vercel URL once deployed).
VITE_GOOGLE_CLIENT_ID=

# The one Google account allowed to edit. Everyone else is view-only.
# Used by the API middleware (enforcement) and the UI (hiding edit controls).
VITE_ALLOWED_EMAIL=
